# .env.example
# ------------
# Copy this file to .env and fill in your own values.
# The .env file is loaded by python-dotenv at startup.
# NEVER commit your real .env file to git — add it to .gitignore!
#
# This .env.example file IS safe to commit — it contains no real secrets,
# just placeholder values showing what keys are needed.

SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
